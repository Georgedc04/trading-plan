generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  createdAt DateTime @default(now())

  plans TradingPlan[]
}

model TradingPlan {
  id        Int      @id @default(autoincrement())
  userId    String
  week      Int
  day       String
  session   String
  result    String
  pair      String?
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
