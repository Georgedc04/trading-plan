generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  createdAt DateTime @default(now())

  plans TradingPlan[]
}

model TradingPlan {
  id        Int      @id @default(autoincrement())
  userId    String
  date      DateTime
  week      Int
  day       String
  session   String
  result    String
  amount    Float    @default(0)
  pair      String?
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes for performance (VERY IMPORTANT)
  @@index([userId])
  @@index([date])
  @@index([result])
  @@index([session])
  @@index([week])

  // Prevent duplicate trade per session per day
  @@unique([userId, date, session])
}